# ─────────────────────────────────────────────────────────────
# Rising Star School — Backend environment variables
# Copy this file to `.env` and fill in real values for your setup.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=5000

# Database — local MongoDB or a MongoDB Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/rising-star-school

# Auth
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
COOKIE_EXPIRES_DAYS=7

# Frontend origin(s) allowed by CORS (comma-separated). Used in production.
CLIENT_URL=http://localhost:5173

# First admin account created once by `npm run seed`
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@risingstarschool.edu.in
SEED_ADMIN_PASSWORD=ChangeThisPassword123!

# ── Optional integrations (safe to leave blank for local development) ──
# Cloudinary (image uploads are skipped when blank)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email notifications via Nodemailer / Gmail (skipped when blank)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=Rising Star Public School
ADMIN_NOTIFY_EMAIL=

# Twilio SMS / WhatsApp (skipped when blank)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
